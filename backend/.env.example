# ─── Database Configuration ───
# Option 1: Use individual components (for local development)
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=threattron_itd

# Option 2: Use full SQLAlchemy URL (for Render/production)
# This will override the individual components above
# Format: mysql+pymysql://user:password@host:port/database
# Example for Railway MySQL: DATABASE_URL=mysql+pymysql://user:password@gateway.railway.app:3306/railway
DATABASE_URL=

# ─── CORS Configuration (for Render deployment) ───
# Comma-separated list of allowed origins
# Local development: http://localhost:5173,http://127.0.0.1:5173
# With Render frontend: https://your-render-frontend.onrender.com,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
